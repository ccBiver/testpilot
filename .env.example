# AI 探索模式所需的多模态模型配置(Midscene),不配置则只能用 --mode heuristic
# 参考 https://midscenejs.com/model-provider.html
OPENAI_API_KEY=
OPENAI_BASE_URL=
MIDSCENE_MODEL_NAME=

# 示例:使用阿里云 Qwen-VL
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MIDSCENE_MODEL_NAME=qwen-vl-max-latest
# MIDSCENE_USE_QWEN_VL=1
