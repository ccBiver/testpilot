{
  "name": "@biver/testpilot",
  "version": "0.2.0",
  "description": "TestPilot — 本地 AI 测试工具:AI 像真实用户一样试飞 Web/Android/iOS,自主探索找 Bug,从需求文档与 Figma 生成用例并执行,本机 Claude 驱动零 API 成本。",
  "type": "module",
  "license": "MIT",
  "bin": {
    "testpilot": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "explore": "tsx src/index.ts explore",
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@midscene/android": "^1.10.4",
    "@midscene/ios": "^1.10.5",
    "@midscene/web": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "commander": "^13.1.0",
    "mammoth": "^1.12.0",
    "pdf-parse-new": "^2.1.0",
    "playwright": "^1.53.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testpilot/detectors": "workspace:*",
    "@testpilot/engine": "workspace:*",
    "@testpilot/executor": "workspace:*",
    "@testpilot/shared": "workspace:*",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.7"
  }
}
