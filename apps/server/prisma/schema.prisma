// M1 认证切片先用 SQLite 零依赖起步;做到 Run/Finding 存储(需要 Json 字段)时
// 将 provider 切为 postgresql 并启用 docker-compose 里的 PG。字段保持 PG 兼容。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  // user | admin(SQLite 无枚举,应用层校验)
  role         String    @default("user")
  // active | disabled
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  runs         Run[]
  issues       Issue[]
  modelConfig  ModelConfig?
}

// 用户自带模型 Key(BYOK):apiKey 用 AES-256-GCM 加密落库,永不明文返回
model ModelConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseUrl   String
  modelName String
  apiKeyEnc String
  // none | qwen(Qwen-VL 坐标兼容模式)
  vlMode    String   @default("none")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  // 被测目标,M1 先支持 web url;M2 扩展 android 包
  targetUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  runs      Run[]
  issues    Issue[]

  @@index([userId])
}

// 看板上的 Bug:跨运行按指纹聚合后的实体;Finding 是每次运行的原始发现(不可变,存于 Run.reportJson)
model Issue {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint String
  detector    String
  // critical | high | medium | low(取历次出现的最高级别)
  severity    String
  title       String
  // open(待确认) | confirmed(已确认) | fixing(修复中) | closed(已关闭) | false_positive(误报)
  status      String  @default("open")
  occurrences Int     @default(1)
  // 最近一次命中的 Finding 快照 JSON(证据/截图/stepSeq),配合 lastRunId 查复现步骤
  findingJson String
  firstRunId  String
  lastRunId   String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, fingerprint])
  @@index([projectId, status])
  @@index([userId])
}

model Run {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // heuristic | ai
  mode       String    @default("heuristic")
  // queued | running | done | failed
  status     String    @default("queued")
  goal       String?
  stepBudget Int       @default(30)
  error      String?
  // 完整 RunReport 的 JSON 文本(SQLite 无 Json 类型;整存整取,切 PG 时改 Json 列)
  reportJson String?
  // 冗余汇总字段,列表页免解析大 JSON
  findingsCount Int      @default(0)
  criticalCount Int      @default(0)
  stepsTaken    Int      @default(0)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([projectId])
  @@index([userId])
}
